generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String?
  planType         String   @default("FREE")
  stripeCustomerId String?
  createdAt        DateTime @default(now())
  scripts          Script[]
  usage            Usage[]
}

model Script {
  id        String   @id @default(uuid())
  userId    String
  topic     String
  audience  String
  tone      String
  length    Int
  output    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Usage {
  id     String @id @default(uuid())
  userId String
  month  String
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model UserEvent {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  event     String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
}
