# Innkwise Vercel environment variable checklist.
# Do not commit real secrets. Add these values in Vercel Project Settings -> Environment Variables.

# App URLs / auth
NEXT_PUBLIC_APP_URL=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
JWT_SECRET=

# Supabase / Postgres
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI providers
HF_API_TOKEN=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
EMBEDDING_TIMEOUT_MS=4000

# Lemon Squeezy billing
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRODUCT_ID=
LEMON_FOUNDER_INDIA_VARIANT_ID=
LEMON_CREATOR_INDIA_VARIANT_ID=
LEMON_FOUNDER_GLOBAL_VARIANT_ID=
LEMON_CREATOR_GLOBAL_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Optional billing/debug controls
BILLING_COUNTRY_OVERRIDE=
ADMIN_USER_IDS=

# Optional rate-limit overrides
RATE_LIMIT_FREE_AI_GENERATIONS_PER_DAY=
RATE_LIMIT_FREE_EMBEDDINGS_PER_DAY=
RATE_LIMIT_FREE_UPLOADS_PER_DAY=
RATE_LIMIT_FREE_MAX_PROMPT_CHARS=
RATE_LIMIT_PRO_AI_GENERATIONS_PER_DAY=
RATE_LIMIT_PRO_EMBEDDINGS_PER_DAY=
RATE_LIMIT_PRO_UPLOADS_PER_DAY=
RATE_LIMIT_PRO_MAX_PROMPT_CHARS=
